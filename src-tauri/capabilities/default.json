{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "notification:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",

    {
      "identifier": "sql:default",
      "allow": [
        {
          "path": "sqlite:heatmap.db"
        }
      ]
    }
  ]
}